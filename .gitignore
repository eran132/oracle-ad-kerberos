# Secrets — local-only credentials for installers / sync wrapper.
# Track .env.example as a documented template; never commit .env itself.
.env
.env.local

# Claude Code per-user settings (auto-allow rules, conversation routing)
.claude/

# Vagrant local state (per-VM keys, machine indexes)
.vagrant/

# Offline-install binaries; large, re-fetchable via lab/tools/stage-offline-bundle.ps1
# Belt-and-suspenders with lab/bundle/.gitignore.
lab/bundle/*
!lab/bundle/.gitignore
!lab/bundle/README.md

# Screenshots staged but not yet captured
screenshots/*.png

# OS junk
Thumbs.db
Desktop.ini
.DS_Store

# Editor / IDE
*.swp
*.swo
.vscode/
.idea/

# Logs / temp
*.log
*.tmp
*.bak
