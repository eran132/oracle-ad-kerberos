# MIT Kerberos for Windows configuration for the mylab.local AD lab.
# Place at: C:\ProgramData\MIT\Kerberos5\krb5.ini
# 1:1 mirror of ..\..\..\tableau_ad_oracle\config\krb5.conf.example
# Enctypes match the AES256-SHA1 keytab generated by ktpass-keytabs.ps1.

[libdefaults]
  default_realm = MYLAB.LOCAL
  dns_lookup_realm = false
  dns_lookup_kdc = true
  rdns = false
  forwardable = true
  default_tkt_enctypes = aes256-cts-hmac-sha1-96 aes128-cts-hmac-sha1-96
  default_tgs_enctypes = aes256-cts-hmac-sha1-96 aes128-cts-hmac-sha1-96
  permitted_enctypes   = aes256-cts-hmac-sha1-96 aes128-cts-hmac-sha1-96

[realms]
  MYLAB.LOCAL = {
    kdc = ad1.mylab.local
    admin_server = ad1.mylab.local
  }

[domain_realm]
  .mylab.local = MYLAB.LOCAL
  mylab.local  = MYLAB.LOCAL
