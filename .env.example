# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Consumed by:
#   scripts/oracle/run-ad-sync-install.sh — passes LDAP_BIND_PWD into
#   sqlplus as the &bind_pwd substitution variable used by the installer.
#
# Never quote the values. Never put a trailing comment on the same line.

# AD service account that the Oracle ad_sync package binds to AD with over
# LDAPS-636 to read group membership.
LDAP_BIND_DN=svc-ora-ldap@MYLAB.LOCAL
LDAP_BIND_PWD=__set_to_the_real_AD_password__

# (Optional) AD service account that holds the Oracle SPN — only used by the
# wallet-build script if you re-generate the wallet from scratch.
SPN_SVC_PWD=__set_to_the_real_AD_password__
